# Environment variables for semantic search

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Pinecone
PINECONE_API_KEY=your-pinecone-key
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=aisa403-search

# Simple API key for the search endpoints (optional)
SEARCH_API_KEY=some-secret-key

# Source dir to index
SEARCH_SOURCE_DIR=./agents
EMBED_BATCH_SIZE=16
